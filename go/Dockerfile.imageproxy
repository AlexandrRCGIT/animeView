FROM golang:1.23-bullseye AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=1 GOOS=linux go build -o imageproxy ./cmd/imageproxy

FROM debian:bullseye-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/imageproxy /usr/local/bin/imageproxy
EXPOSE 8080
CMD ["imageproxy"]
